{
  "name": "@platforma-open/milaboratories.3d-structure-prediction",
  "version": "1.1.0",
  "scripts": {
    "build": "shx rm -rf ./block-pack && block-tools pack",
    "mark-stable": "block-tools mark-stable -r 's3://milab-euce1-prod-pkgs-s3-block-registry/pub/releases/?region=eu-central-1'",
    "prepublishOnly": "block-tools pack && block-tools publish --unstable -r 's3://milab-euce1-prod-pkgs-s3-block-registry/pub/releases/?region=eu-central-1'",
    "do-pack": "shx rm -f *.tgz && block-tools pack && pnpm pack && shx mv *.tgz package.tgz"
  },
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "dependencies": {
    "@platforma-open/milaboratories.3d-structure-prediction.workflow": "workspace:*",
    "@platforma-open/milaboratories.3d-structure-prediction.model": "workspace:*",
    "@platforma-open/milaboratories.3d-structure-prediction.ui": "workspace:*"
  },
  "block": {
    "components": {
      "workflow": "@platforma-open/milaboratories.3d-structure-prediction.workflow/dist/tengo/tpl/main.plj.gz",
      "model": "@platforma-open/milaboratories.3d-structure-prediction.model/dist/model.json",
      "ui": "@platforma-open/milaboratories.3d-structure-prediction.ui/dist"
    },
    "meta": {
      "title": "3D Structure Prediction",
      "logo": "file:../logos/block-logo.png",
      "url": "https://github.com/platforma-open/milaboratories.3d-structure-prediction",
      "support": "mailto:support@milaboratories.com",
      "description": "Predicts antibody and VHH 3D structures with ImmuneBuilder. Emits IMGT-numbered per-clonotype PDB files with per-residue confidence.",
      "longDescription": "file:../docs/description.md",
      "changelog": "file:../CHANGELOG.md",
      "tags": [
        "airr",
        "downstream",
        "antibody",
        "structure"
      ],
      "organization": {
        "name": "MiLaboratories Inc",
        "url": "https://milaboratories.com/",
        "logo": "file:../logos/organization-logo.png"
      },
      "supportedPlatforms": [
        "linux-x64",
        "macosx-aarch64"
      ]
    }
  },
  "devDependencies": {
    "@platforma-sdk/block-tools": "catalog:"
  },
  "packageManager": "pnpm@9.12.0"
}
