{
  "name": "@platforma-open/milaboratories.3d-structure-prediction.software",
  "version": "1.1.0",
  "description": "Block Software",
  "files": [
    "./dist/**/*"
  ],
  "type": "module",
  "scripts": {
    "do-pack": "shx rm -f *.tgz && pl-pkg build && pnpm pack && shx mv platforma-open*.tgz package.tgz",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "build": "pl-pkg build",
    "prepublishOnly": "pl-pkg prepublish"
  },
  "devDependencies": {
    "@platforma-open/milaboratories.runenv-python-3": "catalog:",
    "@platforma-sdk/package-builder": "catalog:"
  },
  "block-software": {
    "artifacts": {
      "py-archive": {
        "type": "python",
        "registry": "platforma-open",
        "environment": "@platforma-open/milaboratories.runenv-python-3:3.12.10-atls",
        "dependencies": {
          "toolset": "pip",
          "requirements": "requirements.txt"
        },
        "root": "./src_python"
      },
      "py-docker": {
        "type": "docker",
        "context": "src_python",
        "dockerfile": "Dockerfile"
      }
    },
    "entrypoints": {
      "immunebuilder-predict": {
        "binary": {
          "artifact": "py-archive",
          "cmd": [
            "python",
            "{pkg}/run_immunebuilder.py"
          ]
        },
        "docker": {
          "artifact": "py-docker",
          "cmd": [
            "python",
            "/app/run_immunebuilder.py"
          ]
        }
      }
    }
  }
}
